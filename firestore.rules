rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function classDoc(classId) {
      return get(/databases/$(database)/documents/classes/$(classId));
    }

    function isStudentInClass(classId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/classes/$(classId)/students/$(request.auth.uid));
    }

    function isClassOwner(classId) {
      return signedIn() &&
        classDoc(classId).data.teacherId == request.auth.uid;
    }

    function sessionDoc(sessionId) {
      return get(/databases/$(database)/documents/attendanceSessions/$(sessionId));
    }

    function isSessionOwner(sessionId) {
      return signedIn() &&
        sessionDoc(sessionId).data.teacherId == request.auth.uid;
    }

    function isSubjectOwner(subjectId) {
      return signedIn() &&
        get(/databases/$(database)/documents/subjects/$(subjectId)).data.createdBy == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isExamVisibleToStudent() {
      // Cho phép mọi học sinh đã đăng nhập đọc metadata bài thi (không chứa đáp án)
      // Điều này giải quyết lỗi permission denied khi nộp bài
      return signedIn();
    }

    // =========================
    // USERS (Web App)
    // App web lưu user profile tại: users/{uid}
    // =========================
    match /users/{uid} {
      // Cho phép authenticated users đọc thông tin user khác (để show student list, teacher info)
      allow read: if signedIn();

      // Cho phép tạo student profile (for teachers adding students)
      allow create: if signedIn() && (
        // User tự tạo profile của mình
        isSelf(uid) ||
        // HOẶC: Cho phép tạo student profile (role == 'student')
        request.resource.data.role == 'student' ||
        // Admin có thể tạo user nào
        isAdmin()
      );

      // Chỉ cho phép user tự chỉnh sửa/xóa profile của mình, hoặc admin
      allow update, delete: if isSelf(uid) || isAdmin();
    }

    // =========================
    // TEACHERS (Mobile App)
    // App mobile đọc tại: teachers/{uid}
    // =========================
    match /teachers/{uid} {
      allow read, write: if isSelf(uid) || isAdmin();
    }

    // =========================
    // CLASSES
    // App query lớp theo teacherId hoặc student enrollment
    // =========================
    match /classes/{classId} {
      // Đọc lớp:
      // - Teacher có thể đọc lớp của mình
      // - Student có thể đọc lớp mà mình được enroll
      // - Admin có thể đọc tất cả lớp
      // - Cho phép query khi filter theo teacherId hoặc students array
      allow read: if signedIn() && (
        // Đọc document cụ thể: kiểm tra ownership
        resource.data.teacherId == request.auth.uid ||
        isStudentInClass(classId) ||
        isAdmin()
      );

      // Cho phép list/query classes
      allow list: if signedIn();

      // Tạo lớp: teacherId phải là UID đang đăng nhập, hoặc admin
      allow create: if signedIn() && (
        request.resource.data.teacherId == request.auth.uid ||
        isAdmin()
      );

      // Sửa/xóa lớp: chỉ chủ lớp hoặc admin
      allow update, delete: if signedIn() && (
        resource.data.teacherId == request.auth.uid ||
        isAdmin()
      );

      // =========================
      // STUDENTS SUBCOLLECTION
      // App dùng: classes/{classId}/students/{studentId}
      // =========================
      match /students/{studentId} {
        allow read, create, update, delete: if signedIn() && (
          classDoc(classId).data.teacherId == request.auth.uid ||
          isSelf(studentId) ||
          isAdmin()
        );
      }

      // =========================
      // TAGS SUBCOLLECTION
      // Web dùng: classes/{classId}/tags/{tagId}
      // =========================
      match /tags/{tagId} {
        allow read: if signedIn() && (
          isClassOwner(classId) ||
          isStudentInClass(classId) ||
          isAdmin()
        );
        allow create, update, delete: if isClassOwner(classId) || isAdmin();
      }

      // =========================
      // STUDENT TAGS SUBCOLLECTION
      // Web dùng: classes/{classId}/studentTags/{docId}
      // =========================
      match /studentTags/{docId} {
        allow read: if signedIn() && (
          isClassOwner(classId) ||
          (isStudentInClass(classId) && resource.data.studentId == request.auth.uid) ||
          isAdmin()
        );
        allow create, update, delete: if isClassOwner(classId) || isAdmin();
      }

      // =========================
      // CLASS EXAMS (snapshot per class)
      // Web dùng: classes/{classId}/classExams/{examId}
      // =========================
      match /classExams/{examId} {
        allow read: if signedIn() && (
          isClassOwner(classId) ||
          isStudentInClass(classId) ||
          isAdmin()
        );
        allow create, update, delete: if isClassOwner(classId) || isAdmin();
      }
    }

    // =========================
    // ATTENDANCE SESSIONS
    // App dùng: attendanceSessions/{sessionId}
    // =========================
    match /attendanceSessions/{sessionId} {
      // Giáo viên hoặc sinh viên trong lớp được xem buổi điểm danh, hoặc admin
      allow read: if signedIn() && (
        resource.data.teacherId == request.auth.uid ||
        isStudentInClass(resource.data.classId) ||
        isAdmin()
      );

      allow list: if signedIn();

      allow create: if signedIn() && (
        request.resource.data.teacherId == request.auth.uid ||
        isAdmin()
      );

      allow update, delete: if signedIn() && (
        resource.data.teacherId == request.auth.uid ||
        isAdmin()
      );

      match /records/{studentId} {
        allow read: if signedIn() && (
          sessionDoc(sessionId).data.teacherId == request.auth.uid ||
          (studentId == request.auth.uid &&
            isStudentInClass(sessionDoc(sessionId).data.classId)) ||
          isAdmin()
        );
        allow create, update, delete: if signedIn() && (
          sessionDoc(sessionId).data.teacherId == request.auth.uid ||
          isAdmin()
        );
      }
    }

    // =========================
    // SUBJECTS (New Structure)
    // Web dùng: subjects/{subjectId}
    // =========================
    match /subjects/{subjectId} {
      // Teacher owner có thể đọc/ghi subject, student chỉ đọc
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if signedIn() &&
        resource.data.createdBy == request.auth.uid;

      // =========================
      // TOPICS SUBCOLLECTION
      // =========================
      match /topics/{topicId} {
        allow read: if signedIn();
        allow create, update, delete: if isSubjectOwner(subjectId);

        // =========================
        // QUESTIONS SUBCOLLECTION
        // =========================
        match /questions/{questionId} {
          allow read: if signedIn();
          allow create, update, delete: if isSubjectOwner(subjectId);
        }

        // =========================
        // ATTACHMENTS SUBCOLLECTION
        // =========================
        match /attachments/{attachmentId} {
          allow read: if signedIn();
          allow create, update, delete: if isSubjectOwner(subjectId);
        }
      }
    }

    // =========================
    // EXAMS
    // Web dùng: exams/{examId}
    // =========================
    match /exams/{examId} {
      // Teacher có thể đọc bài thi của mình
      // Student: bài public toàn cục (legacy) hoặc mở cho lớp đã enroll
      allow read: if signedIn() && (
        resource.data.teacherId == request.auth.uid ||
        resource.data.visibility == 'public' ||
        isExamVisibleToStudent()
      );

      allow list: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.teacherId == request.auth.uid;

      allow update, delete: if signedIn() &&
        resource.data.teacherId == request.auth.uid;
    }

    // =========================
    // EXAM ATTEMPTS
    // Web dùng: examAttempts/{attemptId}
    // =========================
    match /examAttempts/{attemptId} {
      // Student có thể đọc attempts của chính mình
      // Teacher có thể đọc attempts của bài thi của mình
      allow read: if signedIn() && (
        resource.data.studentId == request.auth.uid ||
        get(/databases/$(database)/documents/exams/$(resource.data.examId)).data.teacherId == request.auth.uid
      );

      allow list: if signedIn();

      // Tạo attempt: studentId phải là user hiện tại
      allow create: if signedIn() &&
        request.resource.data.studentId == request.auth.uid;

      // Cập nhật attempt: sinh viên khi làm bài, giáo viên chủ bài thi khi chấm tự luận
      allow update: if signedIn() && (
        resource.data.studentId == request.auth.uid ||
        get(/databases/$(database)/documents/exams/$(resource.data.examId)).data.teacherId == request.auth.uid
      );

      // Giáo viên chủ bài thi có thể xóa attempt (vd. gỡ bài khỏi lớp)
      allow delete: if signedIn() &&
        get(/databases/$(database)/documents/exams/$(resource.data.examId)).data.teacherId == request.auth.uid;
    }

    // =========================
    // QUESTIONS (Collection Group Fallback)
    // Ensures collectionGroup("questions") reads honor the same signed-in rule
    // =========================
    match /{path=**}/questions/{questionId} {
      allow read: if signedIn();
    }
  }
}

