# Cấu hình backend trên Railway/Render — dùng với GitHub Pages
# Copy các biến này vào Railway → Variables (KHÔNG commit .env)

PORT=3001
NODE_ENV=production

# --- Khuyên dùng: Google Gemini (miễn phí, không api-version) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=<lấy tại https://aistudio.google.com/apikey>
GEMINI_MODEL=gemini-2.0-flash

# --- Hoặc: Groq (OpenAI-compatible) ---
# AI_PROVIDER=groq
# AI_API_KEY=<groq api key>
# AI_API_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
# SKIP_API_VERSION=true

CORS_ORIGIN=https://phuctt205dev.github.io,http://localhost:5173

AI_CHUNK_SIZE=4000
AI_CHUNK_OVERLAP=200
AI_MAX_CHUNKS=6
MAX_FILE_SIZE_MB=10
