# Sao chép thành server/.env để dùng Ollama (local, miễn phí)
#   cd server
#   copy .env.ollama.example .env

PORT=3001
AI_PROVIDER=ollama

# OpenAI-compatible endpoint của Ollama (mặc định)
AI_API_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_HOST=http://127.0.0.1:11434

# Model phải đã pull: ollama pull llama3.2
AI_MODEL=llama3.2

# Ollama không cần API key — để trống hoặc giá trị bất kỳ
AI_API_KEY=

SKIP_API_VERSION=true

# Local chậm hơn cloud — giảm số đoạn xử lý
AI_CHUNK_SIZE=3500
AI_CHUNK_OVERLAP=150
AI_MAX_CHUNKS=4
AI_REQUEST_TIMEOUT_MS=300000

MAX_FILE_SIZE_MB=10
CORS_ORIGIN=http://localhost:5173
