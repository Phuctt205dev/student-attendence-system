# Local dev + mẫu cho Railway (GitHub Pages)
#   cd server
#   copy .env.gemini.example .env
#   Dán GEMINI_API_KEY từ https://aistudio.google.com/apikey

PORT=3001
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

CORS_ORIGIN=http://localhost:5173,https://phuctt205dev.github.io

AI_CHUNK_SIZE=4000
AI_CHUNK_OVERLAP=200
AI_MAX_CHUNKS=6
AI_REQUEST_TIMEOUT_MS=120000
MAX_FILE_SIZE_MB=10
