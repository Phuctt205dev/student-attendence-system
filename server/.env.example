PORT=3001

# Azure OpenAI / Foundry (OpenAI-compatible chat completions)
AI_API_KEY=your_api_key_here
AI_API_BASE_URL=AI_API_KEY=https://YOUR-RESOURCE.openai.azure.com/openai/v1
AI_MODEL=gpt-oss-120b

# Text chunking
AI_CHUNK_SIZE=4000
AI_CHUNK_OVERLAP=200
AI_MAX_CHUNKS=8

# Upload limits
MAX_FILE_SIZE_MB=10

# CORS (comma-separated origins, or * for dev)
CORS_ORIGIN=http://localhost:5173
