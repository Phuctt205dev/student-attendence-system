PORT=3001

# Azure OpenAI / Foundry (OpenAI-compatible chat completions)
AI_API_KEY=your_api_key_here
AI_API_BASE_URL=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT/openai/v1
AI_MODEL=gpt-oss-120b

# Text chunking
AI_CHUNK_SIZE=4000
AI_CHUNK_OVERLAP=200
AI_MAX_CHUNKS=8

# Upload limits
MAX_FILE_SIZE_MB=10

# CORS: origin only (no path). Comma-separated for multiple sites.
CORS_ORIGIN=http://localhost:5173,https://phuctt205dev.github.io
