PORT=3001

# Azure AI Projects Agent (for automatic exam generation)
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENT_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your_project
AZURE_AGENT_NAME=roll-call-AI
AZURE_AGENT_VERSION=2

# Text chunking
AI_CHUNK_SIZE=4000
AI_CHUNK_OVERLAP=200
AI_MAX_CHUNKS=8

# Upload limits
MAX_FILE_SIZE_MB=10

# CORS: origin only (no path). Comma-separated for multiple sites.
CORS_ORIGIN=http://localhost:5173,https://phuctt205dev.github.io
