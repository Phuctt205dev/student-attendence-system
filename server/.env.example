PORT=3001

# --- Ollama (local, khuyên dùng khi dev) — xem OLLAMA_SETUP.md ---
# AI_PROVIDER=ollama
# AI_API_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_HOST=http://127.0.0.1:11434
# AI_MODEL=llama3.2
# AI_API_KEY=
# SKIP_API_VERSION=true
# Sao chép nhanh: copy .env.ollama.example .env

# --- Azure / cloud (production) ---
AI_API_KEY=your_api_key_here
AI_API_BASE_URL=https://roll-call-website-resource.openai.azure.com/openai/v1
AI_MODEL=gpt-oss-120b
AI_API_VERSION=2024-08-01-preview
# Set SKIP_API_VERSION=true if your AI provider does not require api-version in the URL
SKIP_API_VERSION=true
# Text chunking
AI_CHUNK_SIZE=4000
AI_CHUNK_OVERLAP=200
AI_MAX_CHUNKS=8

# Upload limits
MAX_FILE_SIZE_MB=10

# CORS: origin only (no path). Comma-separated for multiple sites.
CORS_ORIGIN=http://localhost:5173,https://phuctt205dev.github.io
